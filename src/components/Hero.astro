---
import { business } from '../data/site';
---

<section class="hero" id="top" aria-label="Hero">
  <div class="hero-inner">
    <div class="hero-copy reveal">
      <div class="hero-kicker">
        <span></span>
        Manual motorcycle rental · Galle, Sri Lanka
      </div>
      <h1>
        Real<br />motorcycles.<br />
        <em>Real roads.</em>
      </h1>
      <p class="hero-sub">
        No scooters. No automatics. Just a proper motorbike with a clutch on Sri Lanka's south coast — for riders who know how to shift gears.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={business.whatsapp} target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.126 1.534 5.866L.063 23.998l6.297-1.45A11.934 11.934 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.784 9.784 0 0 1-5.016-1.374l-.36-.214-3.736.978.995-3.63-.235-.374A9.79 9.79 0 0 1 2.182 12c0-5.418 4.4-9.818 9.818-9.818s9.818 4.4 9.818 9.818-4.4 9.818-9.818 9.818z"/></svg>
          Book via WhatsApp
        </a>
        <a class="button button-secondary" href="#bikes">View our bike</a>
      </div>
      <ul class="hero-pills" role="list">
        <li>150cc engine</li>
        <li>Manual gearbox</li>
        <li>Galle · Mirissa · Weligama · Ahangama</li>
        <li>Daily / weekly / monthly</li>
      </ul>
      <p class="hero-disclaimer">Valid motorcycle licence required. This is not a scooter rental.</p>
    </div>

    <div class="hero-card-wrap reveal" style="animation-delay: 0.15s">
      <article class="card hero-card">
        <div class="badge-row">
          <span class="badge badge-orange">Manual Gearbox</span>
          <span class="badge badge-dark">150cc</span>
        </div>
        <h2 class="hero-card-title">{business.bike.model}</h2>
        <p class="hero-card-sub">A real motorbike. Clutch lever. Gear shift. The whole thing.</p>
        <dl class="hero-card-detail">
          <div class="hero-card-row">
            <span>Engine</span>
            <strong>{business.bike.engine}</strong>
          </div>
          <div class="hero-card-row">
            <span>Gearbox</span>
            <strong>{business.bike.gearbox} — shift gears</strong>
          </div>
          <div class="hero-card-row">
            <span>Licence</span>
            <strong>Required — always</strong>
          </div>
          <div class="hero-card-row">
            <span>Deposit</span>
            <strong>{business.terms.deposit}</strong>
          </div>
          <div class="hero-card-row">
            <span>Location</span>
            <strong>Galle, south coast</strong>
          </div>
        </dl>
        <div class="hero-card-cta">
          <a class="button button-primary" href={business.whatsapp} target="_blank" rel="noopener noreferrer">
            Check availability on WhatsApp
          </a>
        </div>
      </article>
    </div>
  </div>
</section>
