---
interface Props {
  flip?: boolean;
  accent?: boolean;
}
const { flip = false, accent = false } = Astro.props;
---

<div class={`section-divider${flip ? ' flip' : ''}${accent ? ' accent' : ''}`} aria-hidden="true">
  <svg
    viewBox="0 0 1440 48"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M0,24 C240,0 480,48 720,24 C960,0 1200,48 1440,24 L1440,48 L0,48 Z"
      fill="currentColor"
    />
  </svg>
</div>

<style>
  .section-divider {
    display: block;
    line-height: 0;
    overflow: hidden;
    color: #0a0a0a;
    margin-bottom: -2px;
  }
  .section-divider.flip {
    transform: scaleY(-1);
    margin-top: -2px;
    margin-bottom: 0;
  }
  .section-divider.accent {
    color: rgba(255, 107, 0, 0.06);
  }
  .section-divider svg {
    width: 100%;
    height: 48px;
    display: block;
  }
</style>
