---
import { business, navLinks } from '../data/site';
const base = import.meta.env.BASE_URL;
---

<header class="site-header" id="top">
  <div class="container header-inner">
    <a class="brand" href="#top" aria-label="Asintha Rent Motorbike — home">
      <img
        src={`${base}logo.png`}
        alt="Asintha Rent Motorbike logo"
        width="52"
        height="52"
        loading="eager"
        class="brand-logo-img"
      />
      <span class="brand-text">
        <strong>Asintha</strong>
        <small>Real motorcycle rental · Galle</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <div class="header-cta">
      <a class="button button-ghost" href={business.callLink} aria-label="Call us">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6.26 6.26l1.17-1.17a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call
      </a>
      <a class="button button-primary" href={business.whatsapp} target="_blank" rel="noopener noreferrer">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.557 4.126 1.534 5.866L.063 23.998l6.297-1.45A11.934 11.934 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.784 9.784 0 0 1-5.016-1.374l-.36-.214-3.736.978.995-3.63-.235-.374A9.79 9.79 0 0 1 2.182 12c0-5.418 4.4-9.818 9.818-9.818s9.818 4.4 9.818 9.818-4.4 9.818-9.818 9.818z"/></svg>
        Book via WhatsApp
      </a>
      <button class="hamburger" id="menuToggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobileNav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  <nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
    <a href={business.whatsapp} target="_blank" rel="noopener noreferrer">Book via WhatsApp →</a>
  </nav>
</header>

<style>
  .brand-logo-img {
    width: 52px;
    height: 52px;
    object-fit: contain;
    border-radius: 6px;
    flex-shrink: 0;
  }
</style>

<script>
  const btn = document.getElementById('menuToggle');
  const nav = document.getElementById('mobileNav');
  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
