---
import { faqs } from '../data/site';
---

<section class="section" id="faq">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">FAQ</span>
      <h2>Questions before <span>you book.</span></h2>
      <p>
        Straightforward answers for experienced riders. If something isn't covered here, message on WhatsApp.
      </p>
    </div>

    <div class="faq-list reveal">
      {faqs.map((item) => (
        <details class="faq-item">
          <summary>
            {item.question}
            <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </summary>
          <p class="faq-answer">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
