---
import { processSteps } from '../data/site';

const icons = [
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
];
---

<section class="section section-alt" id="how-it-works">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">How it works</span>
      <h2>Three steps. <span>WhatsApp to road.</span></h2>
      <p>
        The process is straightforward — but the requirement is firm. A valid motorcycle licence is non-negotiable before any rental is confirmed.
      </p>
    </div>

    <div class="process-grid">
      {processSteps.map((step, i) => (
        <article class="process-card reveal" style={`animation-delay: ${i * 0.1}s`}>
          <div class="process-num">0{i + 1}</div>
          <span class="process-icon" set:html={icons[i]} />
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
